-- Name: create_dashboard_for_roles(); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.create_dashboard_for_roles() RETURNS trigger
    LANGUAGE plpgsql
    AS $$
BEGIN
    IF NEW.role_name IN ('Agent', 'Manager', 'Admin') THEN
        INSERT INTO public.dashboard (number_of_sales, email)
        VALUES (0, NEW.email);
    END IF;
    RETURN NEW;
END;
$$;


ALTER FUNCTION public.create_dashboard_for_roles() OWNER TO postgres;

