--
-- TOC entry 259 (class 1255 OID 32850)
-- Name: update_dashboard_sales(); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.update_dashboard_sales() RETURNS trigger
    LANGUAGE plpgsql
    AS $$
BEGIN
    -- Aggiorna il numero di vendite nel dashboard associato all'agente
    UPDATE public.dashboard
    SET number_of_sales = number_of_sales + 1
    WHERE email = NEW.email_agent;
    
    RETURN NEW;
END;
$$;


ALTER FUNCTION public.update_dashboard_sales() OWNER TO postgres;

