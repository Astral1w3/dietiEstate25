    LANGUAGE plpgsql
    AS $$
BEGIN
    -- Inserisce l'id della proprietÃ  e l'email della dashboard associata all'agente
    INSERT INTO public.property_dashboard (id_property, email)
    VALUES (NEW.id_property, NEW.email_agent);
    
